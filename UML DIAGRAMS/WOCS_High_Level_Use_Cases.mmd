flowchart LR
    %% Actors
    subgraph Roles["System Users (Role-Based Access)"]
        WO([Warehouse Operator])
        WM([Warehouse Manager])
        ROH([Regional Ops Head])
        FIN([Finance])
        ITA([IT Admin])
