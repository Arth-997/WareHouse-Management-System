```mermaid
---
title: WOCS - High Level Architecture Component Diagram (Phase 1)
---
flowchart TD
    subgraph WOCS["Warehouse Operations & Coordination System (Phase 1)"]
        direction TB
        UI_Web["Web Interface (React/Vue)"]
        UI_Handheld["Handheld Scanner App"]
        API["WOCS API Gateway"]
        
        subgraph CoreServices["Core Microservices/Modules"]
            IAM["Access Control & User Mgt"]
            INV["Inventory Management core"]
            ORD["Order Management Service"]
            SLA["SLA Monitoring Engine"]
            BILL["Billing Module (Phase 1 bounded)"]
            NOTIF["Notification Engine"]
            REP["Reporting & Analytics"]
            AUDIT["Audit & Logging Service"]
        end
        
        DB[(Central WOCS Database)]
    end
    
    %% External Interfaces
    System_Accounting["External Accounting System (Future Integration / Export)"]

    %% User Interactions
    Client("Client User") --> UI_Web
    Operator("Warehouse Operator") --> UI_Handheld
    Finance("Finance User") --> UI_Web
    Admin("IT Administrator") --> UI_Web
    Ops("Regional Ops Head") --> UI_Web

    UI_Web --> API
    UI_Handheld --> API
    
    API --> CoreServices
    CoreServices --> DB
    
    %% Dependencies and logging
    INV -.-> AUDIT
    ORD -.-> AUDIT
    BILL -.-> AUDIT
    IAM -.-> AUDIT
    
    %% Cross Service Communication
    ORD --> SLA
    ORD --> BILL
    INV --> BILL
    SLA --> NOTIF
    INV --> NOTIF
    BILL -.-> System_Accounting

---
title: WOCS - High Level Use Case Diagram
---
flowchart LR
    %% Actors
    subgraph Roles["System Users (Role-Based Access)"]
        WO([Warehouse Operator])
        WM([Warehouse Manager])
        ROH([Regional Ops Head])
        FIN([Finance])
        ITA([IT Admin])
        CU([Client User])
        SC([Sales / Client Servicing])
    end

    %% Use Cases
    subgraph WOCS_UC["Phase 1 Fixed Scope Requirements"]
        UC_Inv["Receive, Adjust, Transfer Inventory"]
        UC_Ord["Process Orders (Pick, Pack, Dispatch)"]
        UC_SLA["Configure & Monitor SLAs"]
        UC_Bill["Configure Billing Rates & Exports"]
        UC_Rule["Configure Warehouse Location Rules"]
        UC_View["View Client Data (Inventory/Order)"]
        UC_Notif["Configure Alerts (Low Stock, Breaches)"]
    end

    %% Mappings
    WO --> UC_Inv
    WO --> UC_Ord
    WM --> UC_Inv
    WM --> UC_Ord
    ROH --> UC_SLA
    FIN --> UC_Bill
    ITA --> UC_Rule
    ITA --> UC_SLA
    ITA --> UC_Notif
    CU --> UC_View
    SC --> UC_View
