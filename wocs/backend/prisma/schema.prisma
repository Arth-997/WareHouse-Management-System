generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  role      String   // IT_ADMINISTRATOR, WAREHOUSE_OPERATOR, WAREHOUSE_MANAGER, FINANCE, CLIENT_USER, CUSTOMER
  name      String
  email     String   @unique
  password  String?  // Made optional for Google Auth users
  googleId  String?  @unique
  avatarUrl String?

  // Optional: links CLIENT_USER to their Client entity
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])

  // Optional: links CUSTOMER to their Customer entity
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  inventoryMovements    InventoryMovement[]
  createdRequests       InventoryRequest[]  @relation("RequestCreator")
  respondedRequests     InventoryRequest[]  @relation("RequestResponder")
}

model Warehouse {
  id                               String   @id @default(uuid())
  code                             String   @unique
  name                             String
  type                             String   // storage_only, fulfillment, temperature_sensitive
  timezone                         String
  address                          String
  isActive                         Boolean  @default(true)
  
  // Configs
  mandatoryLocationAssignment      Boolean  @default(false)
  mandatorySerialCaptureDefault    Boolean  @default(false)
  serialCaptureOverrides           Json?
  slaWarningLeadHours              Int      @default(2)
  maxOfflineBufferMinutes          Int      @default(5)
  notificationFrequency            String   @default("IMMEDIATE") // or DAILY
  lowInventoryThresholdPct         Int      @default(20)

  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
  
  // Relations
  inventoryPositions               InventoryPosition[]
  orders                           Order[]
  inventoryRequests                InventoryRequest[]
}

model Client {
  id               String   @id @default(uuid())
  code             String   @unique
  name             String
  contactEmail     String
  billingCycleDay  Int
  isActive         Boolean  @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  skus             SKU[]
  inventory        InventoryPosition[]
  orders           Order[]
  users            User[]
  inventoryRequests InventoryRequest[]
}

model Customer {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  contactEmail String
  phone        String?
  address      Json?    // { line1, city, state, zip }
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  orders       Order[]
  users        User[]
}

model SKU {
  id             String   @id @default(uuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  skuCode        String
  description    String
  storageType    String   // normal, cold
  trackBatch     Boolean  @default(false)
  trackExpiry    Boolean  @default(false)
  trackSerial    Boolean  @default(false)
  unitOfMeasure  String
  barcode        String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  inventory          InventoryPosition[]
  inventoryRequests  InventoryRequest[]
  orderLines         OrderLine[]
}

model InventoryPosition {
  id               String   @id @default(uuid())
  warehouseId      String
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])
  skuId            String
  sku              SKU      @relation(fields: [skuId], references: [id])
  
  locationId       String?
  batchNumber      String?
  expiryDate       DateTime?
  quantityOnHand   Int      @default(0)
  quantityReserved Int      @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([warehouseId, clientId, skuId, locationId, batchNumber])
}

model Order {
  id               String   @id @default(uuid())
  orderRef         String   @unique
  internalRef      String?
  warehouseId      String
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])

  // The end-buyer
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  
  status           String   // received, allocated, picked, packed, dispatched, delivered
  priority         String   // normal, high
  shippingMethod   String
  billingCategory  String
  deliveryAddress  Json
  
  slaStartAt       DateTime?
  slaDeadlineAt    DateTime?
  slaBreached      Boolean  @default(false)
  
  dispatchedAt     DateTime?
  deliveredAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  lines            OrderLine[]
}

model OrderLine {
  id                   String  @id @default(uuid())
  orderId              String
  order                Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId                String
  sku                  SKU     @relation(fields: [skuId], references: [id])
  quantity             Int
  inventoryPositionId  String?
}

model InventoryMovement {
  id               String   @id @default(uuid())
  movementType     String   // receive, pick, adjust, transfer, reserve, unreserve
  referenceType    String   // Order, Adjustment, Transfer
  referenceId      String?
  
  quantityBefore   Int
  quantityChange   Int
  quantityAfter    Int
  
  reasonCategory   String?
  performedById    String
  performedBy      User     @relation(fields: [performedById], references: [id])
  performedAt      DateTime @default(now())
}

model InventoryRequest {
  id              String   @id @default(uuid())
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  skuId           String
  sku             SKU      @relation(fields: [skuId], references: [id])

  requestedQty    Int
  status          String   @default("pending") // pending, approved, rejected, received
  notes           String?

  requestedById   String
  requestedBy     User     @relation("RequestCreator", fields: [requestedById], references: [id])
  
  respondedById   String?
  respondedBy     User?    @relation("RequestResponder", fields: [respondedById], references: [id])
  respondedAt     DateTime?
  receivedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
