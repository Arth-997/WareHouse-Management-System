generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  role      String   // Operator, Manager, Regional_Ops, Finance, Client, Admin
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  inventoryMovements InventoryMovement[]
}

model Warehouse {
  id                               String   @id @default(uuid())
  code                             String   @unique
  name                             String
  type                             String   // storage_only, fulfillment, temperature_sensitive
  timezone                         String
  address                          String
  isActive                         Boolean  @default(true)
  
  // Configs
  mandatoryLocationAssignment      Boolean  @default(false)
  mandatorySerialCaptureDefault    Boolean  @default(false)
  serialCaptureOverrides           Json?
  slaWarningLeadHours              Int      @default(2)
  maxOfflineBufferMinutes          Int      @default(5)
  notificationFrequency            String   @default("IMMEDIATE") // or DAILY
  lowInventoryThresholdPct         Int      @default(20)

  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
  
  // Relations
  inventoryPositions               InventoryPosition[]
  orders                           Order[]
}

model Client {
  id               String   @id @default(uuid())
  code             String   @unique
  name             String
  contactEmail     String
  billingCycleDay  Int
  isActive         Boolean  @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  skus             SKU[]
  inventory        InventoryPosition[]
  orders           Order[]
}

model SKU {
  id             String   @id @default(uuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  skuCode        String
  description    String
  storageType    String   // normal, cold
  trackBatch     Boolean  @default(false)
  trackExpiry    Boolean  @default(false)
  trackSerial    Boolean  @default(false)
  unitOfMeasure  String
  barcode        String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  inventory      InventoryPosition[]
}

model InventoryPosition {
  id               String   @id @default(uuid())
  warehouseId      String
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])
  skuId            String
  sku              SKU      @relation(fields: [skuId], references: [id])
  
  locationId       String?
  batchNumber      String?
  expiryDate       DateTime?
  quantityOnHand   Int      @default(0)
  quantityReserved Int      @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([warehouseId, clientId, skuId, locationId, batchNumber])
}

model Order {
  id               String   @id @default(uuid())
  orderRef         String   @unique
  internalRef      String?
  warehouseId      String
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])
  
  status           String   // received, allocated, picked, packed, dispatched, delivered
  priority         String   // normal, high
  shippingMethod   String
  billingCategory  String
  deliveryAddress  Json
  
  slaStartAt       DateTime?
  slaDeadlineAt    DateTime?
  slaBreached      Boolean  @default(false)
  
  dispatchedAt     DateTime?
  deliveredAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model InventoryMovement {
  id               String   @id @default(uuid())
  movementType     String   // receive, pick, adjust, transfer
  referenceType    String   // Order, Adjustment, Transfer
  referenceId      String?
  
  quantityBefore   Int
  quantityChange   Int
  quantityAfter    Int
  
  reasonCategory   String?
  performedById    String
  performedBy      User     @relation(fields: [performedById], references: [id])
  performedAt      DateTime @default(now())
}
